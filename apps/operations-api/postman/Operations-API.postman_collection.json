{
  "info": {
    "name": "Operations API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j=pm.response.json(); if(j.accessToken) pm.environment.set('accessToken', j.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@opshub.dev\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j=pm.response.json(); if(j.accessToken) pm.environment.set('accessToken', j.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/dashboard/summary"
          }
        },
        {
          "name": "Alerts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/dashboard/alerts"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/orders?page=1&pageSize=20&status=SHIPPED"
          }
        },
        {
          "name": "Order Details",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/orders/ORD-1045"
          }
        },
        {
          "name": "Update Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"status\":\"SHIPPED\"}"
            },
            "url": "{{baseUrl}}/api/v1/orders/ORD-1045/status"
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "List Inventory",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/inventory"
          }
        },
        {
          "name": "Warehouses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/inventory/warehouses"
          }
        },
        {
          "name": "Transfer Stock",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n \"productId\":\"PROD-001\",\n \"fromWarehouseId\":\"BLR-01\",\n \"toWarehouseId\":\"MUM-01\",\n \"quantity\":2\n}"
            },
            "url": "{{baseUrl}}/api/v1/inventory/transfers"
          }
        }
      ]
    },
    {
      "name": "Refunds",
      "item": [
        {
          "name": "Eligibility",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/refunds/ORD-1045/eligibility"
          }
        },
        {
          "name": "Create Refund",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"orderId\":\"ORD-1045\",\"amount\":1000,\"reason\":\"Product issue\"}"
            },
            "url": "{{baseUrl}}/api/v1/refunds"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/users"
          }
        },
        {
          "name": "Feature Flags",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/feature-flags"
          }
        }
      ]
    }
  ]
}